name: Deploy MkDocs Site

on:
  push:
    branches:
      - main  # triggers on every push to main

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      # 1. Check out the repository
      - name: Checkout repo
        uses: actions/checkout@v3

      # 2. Set up Python
      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.x'

      # 3. Install MkDocs and theme (if using Material theme)
      - name: Install dependencies
        run: |
          pip install mkdocs
          pip install mkdocs-material  # optional

      # 4. Deploy MkDocs site
      - name: Deploy to GitHub Pages
        run: mkdocs gh-deploy \
             --config-file documentation/mkdocs.yml \
             --force \
             --remote-branch gh-pages
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
